# DATABASE CONFIGURATION
DATABASE_URL=postgresql://user:password@localhost:5432/ipb_tracker
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/ipb_tracker_test

# AUTH & SECURITY
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=15

# CELERY & REDIS (Background Tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# EMAIL CONFIGURATION (Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587   
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ipb.ac.id

# AI/LANGCHAIN CONFIGURATION
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LLM Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, local
LLM_MODEL=gpt-4      # Model yang digunakan
LLM_TEMPERATURE=0.7  # Creativity level (0.0 - 1.0)

# FILE STORAGE (CV/Reports)
# Gunakan S3/GCS/Azure Blob
STORAGE_TYPE=local  # Options: local, s3, gcs, azure
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# EXTERNAL APIs (Scraping)
SCRAPING_USER_AGENT=IPB-Internship-Tracker/1.0
SCRAPING_DELAY_SECONDS=2

# APPLICATION SETTINGS
APP_ENV=development  # Options: development, staging, production
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000