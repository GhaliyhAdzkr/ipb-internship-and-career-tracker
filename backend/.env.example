# DATABASE CONFIGURATION
# Connection string ke database PostgreSQL utama
DATABASE_URL=postgresql://user:password@localhost:5432/ipb_tracker
# Connection string khusus untuk menjalankan unit testing
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/ipb_tracker_test

# AUTH & SECURITY
# Kunci rahasia untuk tanda tangan JWT (Gunakan string acak panjang di produksi)
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=15

# CELERY & REDIS (Background Tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/2

# EMAIL CONFIGURATION (SMTP)
# Host SMTP (Contoh: smtp.resend.com atau smtp.gmail.com)
SMTP_HOST=smtp.resend.com
# Port SMTP (465 untuk SSL, 587 untuk TLS)
SMTP_PORT=465
# Username SMTP
SMTP_USER=resend
# Password SMTP atau API Key
SMTP_PASSWORD=re_123456789
# Alamat email pengirim (Harus terverifikasi di provider SMTP)
SMTP_FROM_EMAIL=noreply@laras.ipb.ac.id
# Nama yang muncul di email pengirim
SMTP_FROM_NAME=IPB Internship & Career Tracker

# AI/LANGCHAIN CONFIGURATION
# API Key untuk pemrosesan CV dan matching skill via LLM
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3

# FILE STORAGE (CV/Reports)
STORAGE_TYPE=s3  # Options: local, s3, gcs, azure
# UPLOAD_DIR=./uploads
# Ukuran file maksimal (10MB dalam bytes)
MAX_UPLOAD_SIZE=10485760

# APPLICATION SETTINGS
# Environment aplikasi (development, staging, production)
ENVIRONMENT=development
DEBUG=true
# Origin yang diizinkan untuk CORS (Pisahkan dengan koma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000