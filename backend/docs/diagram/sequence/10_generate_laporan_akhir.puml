@startuml
title Sequence 10 - Generate Laporan Akhir dari Jurnal Harian
autonumber
actor Mahasiswa
participant "Frontend Portal" as FE
participant "Placement API" as API
database "PostgreSQL" as DB
participant "Celery Worker" as Worker
participant "Report Generator" as Report
participant "Storage\nlocal/S3" as Storage
participant "Notification Queue" as Notif

Mahasiswa -> FE: Klik Generate Laporan
FE -> API: POST /placements/{id}/report/generate
API -> DB: Validasi placement milik mahasiswa
API -> API: Cek end_date sudah lewat dan cooldown 5 menit
alt valid
  API -> DB: Update last_report_generated_at
  API -> Worker: Queue generate_final_report(placement_id)
  API --> FE: 202 proses background
  Worker -> Report: Build PDF dari ActivityLogs
  Report -> DB: Query ActivityLogs by placement_id
  DB --> Report: Logs jurnal
  Report -> Storage: Upload reports/report_{id}.pdf
  Storage --> Report: auto_generated_report_url
  Report -> DB: Update Placements.auto_generated_report_url
  Report -> Notif: Insert NotificationQueue QUEUED
else belum selesai/cooldown/tidak ditemukan
  API --> FE: 400/404/429
end
@enduml
